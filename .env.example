# =============================================================================
# AstraTrade — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# --- App ---
APP_ENV=development          # development | production
APP_SECRET_KEY=changeme-use-a-long-random-string
LOG_LEVEL=INFO
SQL_ECHO=0                   # 1=print every SQL statement (includes secrets in WHERE/SET clauses) — dev debugging only, never enable in production

# --- PostgreSQL / TimescaleDB ---
POSTGRES_HOST=database
POSTGRES_PORT=5439
POSTGRES_DB=vcpilot
POSTGRES_USER=vcpilot
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://vcpilot:changeme@database:5432/vcpilot

# --- Redis (Celery broker + result backend) ---
REDIS_HOST=redis
REDIS_PORT=6389
REDIS_URL=redis://redis:6389/0

# --- IBKR Gateway ---
IBKR_HOST=ibkr
IBKR_PORT=4002             # 4001=live, 4002=paper
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=              # Your IBKR account number
IBKR_PAPER_MODE=paper      # paper=paper trading, live=live trading — ALWAYS start paper
NOVNC_URL=https://vnc.astradigital.com.au  # Public URL for noVNC (Cloudflare tunnel subdomain or LAN IP:port)
VNC_PASSWORD=changeme      # Password for VNC/noVNC access to the IBKR Gateway login screen — change this
IBKR_SIMULATE=false        # true=simulate fills locally (sandbox), false=execute orders via IBKR gateway

# IBKR Gateway login (used by the gateway container)
IBKR_USERNAME=
IBKR_PASSWORD=

# --- Data APIs ---
# yfinance is free/unlimited — no key needed
# FMP free tier: 250 calls/day — used only for supplementary fundamentals
FMP_API_KEY=

# --- Dashboard (FastAPI + Jinja2) ---
DASHBOARD_PORT=8501
DASHBOARD_PASSWORD=changeme  # Simple password for the admin dashboard

# --- MCP Server (standalone, optional — see docker-compose.yml mcp-server service) ---
MCP_SERVER_PORT=8502

# --- Super Admin Credentials ---
SUPERADMIN_EMAIL=admin@vcpilot.com
SUPERADMIN_PASSWORD=changeme

# --- Trading Settings (overridden by DB config, these are fallback defaults) ---
TRADING_UNIVERSE=ASX200       # ASX200 | ASX300 | ALLASX
BASE_CURRENCY=AUD
WEEKLY_CAPITAL_INJECTION=1000  # AUD added to account per week

# --- SMTP / Email Settings ---
# For unauthenticated local relay leave USERNAME/PASSWORD blank and SMTP_USE_TLS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AstraTrade

